{% layout none %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Coming Soon</title>
  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
</head>
<body class="template-password" style="display:flex;align-items:center;justify-content:center;min-height:100vh;background:#1a1a1a;color:#fff;">
  <div style="text-align:center;max-width:500px;padding:2rem;">
    <h1>{{ shop.name }}</h1>
    <p>Opening soon. Enter the password to get early access.</p>
    {% form 'storefront_password' %}
      {% if form.errors %}
        <p style="color:#ef4444;">Wrong password. Try again.</p>
      {% endif %}
      <input type="password" name="password" placeholder="Password" style="padding:0.75rem 1rem;border:1px solid #444;background:#333;color:#fff;border-radius:4px;margin-bottom:1rem;width:100%;">
      <button type="submit" class="btn btn-primary" style="width:100%;">Enter</button>
    {% endform %}
  </div>
</body>
</html>
