<div class="customer-page page-width">
  <h1>Activate Account</h1>
  <p>Create your password to activate your account.</p>

  {% form 'activate_customer_password' %}
    {{ form.errors | default_errors }}

    <div class="form-group">
      <label for="ActivatePassword">Password</label>
      <input type="password" name="customer[password]" id="ActivatePassword" autocomplete="new-password" required>
    </div>

    <div class="form-group">
      <label for="ActivatePasswordConfirm">Confirm password</label>
      <input type="password" name="customer[password_confirmation]" id="ActivatePasswordConfirm" autocomplete="new-password" required>
    </div>

    <button type="submit" class="btn btn-primary">Activate account</button>
    <button type="submit" name="decline" class="btn btn-secondary">Decline invitation</button>
  {% endform %}
</div>
