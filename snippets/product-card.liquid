{%- comment -%}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{%- endcomment -%}

<div class="product-card">
  {%- if product.compare_at_price > product.price -%}
    <span class="product-badge product-badge--sale">Sale</span>
  {%- elsif product.available == false -%}
    <span class="product-badge product-badge--soldout">Sold Out</span>
  {%- elsif product.selected_or_first_available_variant.inventory_management == 'shopify' and product.selected_or_first_available_variant.inventory_quantity <= 5 and product.selected_or_first_available_variant.inventory_quantity > 0 -%}
    <span class="product-badge product-badge--low">Only {{ product.selected_or_first_available_variant.inventory_quantity }} left</span>
  {%- endif -%}
  <a href="{{ product.url }}" class="product-card-link">
    {% if product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 400 }}"
        alt="{{ product.featured_image.alt | default: product.title | escape }}"
        width="400"
        height="{{ 400 | divided_by: product.featured_image.aspect_ratio | round }}"
        loading="lazy"
        class="product-card-image"
      >
    {% else %}
      <div class="product-card-placeholder">No image</div>
    {% endif %}

    <div class="product-card-info">
      <h3 class="product-card-title">{{ product.title }}</h3>
      <div class="product-card-price">
        {% if product.compare_at_price > product.price %}
          <s>{{ product.compare_at_price | money }}</s>
        {% endif %}
        <span>{{ product.price | money }}</span>
      </div>
    </div>
  </a>
</div>
