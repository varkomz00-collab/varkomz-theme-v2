{%- paginate collection.products by section.settings.products_per_page -%}
{% render 'breadcrumbs' %}
<div class="collection-page page-width" data-section-id="{{ section.id }}">
  <h1 class="collection-title">{{ collection.title }}</h1>

  {% if collection.description != blank %}
    <div class="collection-description rte">{{ collection.description }}</div>
  {% endif %}

  {% if collection.products.size > 0 %}
    <div class="product-grid grid--{{ section.settings.columns }}-col">
      {% for product in collection.products %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
  {% else %}
    <p style="text-align:center;padding:3rem 0;color:var(--vz-gray);">No products found in this collection.</p>
  {% endif %}

  {% if paginate.pages > 1 %}
    <nav class="pagination" role="navigation" aria-label="Pagination">
      {{ paginate | default_pagination }}
    </nav>
  {% endif %}
</div>
{%- endpaginate -%}

{% schema %}
{
  "name": "Collection Page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 4,
      "max": 48,
      "step": 4,
      "default": 16
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    }
  ]
}
{% endschema %}
