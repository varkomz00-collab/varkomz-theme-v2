<section class="apple-brands" id="Brands-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="apple-brands__title">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="apple-brands__row">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="apple-brands__item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 300 }}"
              alt="{{ block.settings.name | escape }}"
              loading="lazy"
              class="apple-brands__logo"
            >
          {% else %}
            <span class="apple-brands__name">{{ block.settings.name }}</span>
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .apple-brands {
    padding: 80px 0;
    border-top: 1px solid var(--vz-border);
    border-bottom: 1px solid var(--vz-border);
  }
  .apple-brands__title {
    text-align: center;
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--vz-black);
    margin: 0 0 56px;
  }
  .apple-brands__row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 64px;
    flex-wrap: wrap;
  }
  .apple-brands__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.3s ease;
    opacity: 0.45;
  }
  .apple-brands__item:hover {
    opacity: 1;
  }
  .apple-brands__logo {
    max-width: 160px;
    max-height: 60px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%);
    transition: filter 0.3s ease;
  }
  .apple-brands__item:hover .apple-brands__logo {
    filter: grayscale(0%);
  }
  .apple-brands__name {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--vz-black);
  }

  @media (max-width: 734px) {
    .apple-brands { padding: 56px 0; }
    .apple-brands__row { gap: 40px; }
    .apple-brands__title { margin-bottom: 36px; }
    .apple-brands__logo { max-width: 120px; }
    .apple-brands__name { font-size: 18px; }
  }
</style>

{% schema %}
{
  "name": "Brand Showcase",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Official Brand Partners" }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Logo" },
        { "type": "text", "id": "name", "label": "Name", "default": "Brand" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "Brand Showcase", "blocks": [
    { "type": "brand", "settings": { "name": "Tigé Boats", "link": "/collections/all" } },
    { "type": "brand", "settings": { "name": "ATX", "link": "/collections/all" } },
    { "type": "brand", "settings": { "name": "Hyperlite", "link": "/collections/all" } },
    { "type": "brand", "settings": { "name": "HO Sports", "link": "/collections/all" } }
  ] }]
}
{% endschema %}
