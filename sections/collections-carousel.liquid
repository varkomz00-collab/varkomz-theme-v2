<section class="apple-carousel" id="Carousel-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <p class="apple-carousel__eyebrow">{{ section.settings.heading }}</p>
    {% endif %}

    <div class="apple-carousel__container">
      <button class="apple-carousel__arrow apple-carousel__arrow--prev" aria-label="Previous" style="display:none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>

      <div class="apple-carousel__track">
        {% for block in section.blocks %}
          {% case block.type %}
            {% when 'collection_card' %}
              {%- assign col = collections[block.settings.collection] -%}
              <a href="{{ col.url | default: '#' }}" class="apple-carousel__card" {{ block.shopify_attributes }}>
                <div class="apple-carousel__card-media">
                  {% if col.image %}
                    <img src="{{ col.image | image_url: width: 480 }}" alt="{{ col.title | escape }}" loading="lazy">
                  {% else %}
                    <div class="apple-carousel__card-empty"></div>
                  {% endif %}
                </div>
                <div class="apple-carousel__card-info">
                  <h3>{{ block.settings.label | default: col.title }}</h3>
                  <span>{{ col.products_count }} products</span>
                </div>
              </a>
          {% endcase %}
        {% endfor %}
      </div>

      <button class="apple-carousel__arrow apple-carousel__arrow--next" aria-label="Next" style="display:none;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>

    <div class="apple-carousel__dots"></div>
  </div>
</section>

<style>
  .apple-carousel {
    padding: 64px 0 48px;
  }
  .apple-carousel__eyebrow {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 13px;
    font-weight: 600;
    color: var(--vz-gray);
    margin-bottom: 32px;
    font-family: var(--font-heading);
  }
  .apple-carousel__container { position: relative; }
  .apple-carousel__track {
    display: flex;
    gap: 16px;
    scroll-snap-type: x mandatory;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    padding: 8px 0;
  }
  .apple-carousel__track::-webkit-scrollbar { display: none; }
  .apple-carousel__card {
    flex: 0 0 calc(25% - 12px);
    scroll-snap-align: start;
    display: block;
    text-decoration: none;
    color: var(--vz-black);
    border-radius: 20px;
    overflow: hidden;
    background: var(--vz-light-gray);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .apple-carousel__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
  }
  .apple-carousel__card-media {
    aspect-ratio: 4/5;
    overflow: hidden;
  }
  .apple-carousel__card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .apple-carousel__card:hover .apple-carousel__card-media img {
    transform: scale(1.04);
  }
  .apple-carousel__card-empty {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #e8e8ed 0%, #f5f5f7 100%);
  }
  .apple-carousel__card-info {
    padding: 16px 20px 20px;
  }
  .apple-carousel__card-info h3 {
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 4px;
  }
  .apple-carousel__card-info span {
    font-size: 13px;
    color: var(--vz-gray);
  }
  .apple-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255,255,255,0.92);
    border: none;
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 12px rgba(0,0,0,0.1);
    backdrop-filter: blur(8px);
    transition: opacity 0.2s ease;
    color: var(--vz-black);
  }
  .apple-carousel__arrow:hover { opacity: 0.8; }
  .apple-carousel__arrow--prev { left: -22px; }
  .apple-carousel__arrow--next { right: -22px; }
  .apple-carousel__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
  }
  .carousel-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--vz-border); border: none; cursor: pointer; padding: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .carousel-dot.active { background: var(--vz-black); transform: scale(1.2); }

  @media (max-width: 989px) { .apple-carousel__card { flex: 0 0 calc(50% - 8px); } }
  @media (max-width: 734px) {
    .apple-carousel__card { flex: 0 0 72%; }
    .apple-carousel__arrow { display: none !important; }
    .apple-carousel { padding: 48px 0 32px; }
  }
</style>

{% schema %}
{
  "name": "Collections Carousel",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SHOP BY COLLECTION" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "label", "label": "Custom label" }
      ]
    }
  ],
  "presets": [{ "name": "Collections Carousel" }]
}
{% endschema %}
