<section class="collections-carousel-section" id="CollectionsCarousel-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="carousel-heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="carousel-container">
      <button class="carousel-arrow carousel-arrow--prev" aria-label="Previous" style="display:none;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M15 18l-6-6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>

      <div class="carousel-track-wrapper">
        <div class="carousel-track">
          {% for block in section.blocks %}
            {% case block.type %}
              {% when 'collection_card' %}
                {%- assign col = collections[block.settings.collection] -%}
                <a href="{{ col.url | default: '#' }}"
                   class="carousel-card{% if col.handle == collection.handle %} active{% endif %}"
                   {{ block.shopify_attributes }}>
                  {% if col.image %}
                    <img src="{{ col.image | image_url: width: 400 }}" alt="{{ col.title | escape }}" loading="lazy" class="carousel-card-image">
                  {% else %}
                    <div class="carousel-card-image" style="background:var(--vz-light-gray);width:100%;height:100%;"></div>
                  {% endif %}
                  <div class="carousel-card-overlay">
                    <h3 class="carousel-card-title">{{ block.settings.label | default: col.title }}</h3>
                    <span class="carousel-card-count">{{ col.products_count }} products</span>
                  </div>
                </a>
            {% endcase %}
          {% endfor %}
        </div>
      </div>

      <button class="carousel-arrow carousel-arrow--next" aria-label="Next" style="display:none;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M9 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
      </button>
    </div>

    <div class="carousel-dots"></div>
  </div>
</section>

<style>
  .collections-carousel-section { padding: 2.5rem 0; }
  .carousel-heading {
    text-align: center;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-size: 14px;
    font-weight: 500;
    color: var(--vz-gray);
    margin-bottom: 1.5rem;
    font-family: var(--font-heading);
  }
  .carousel-container { position: relative; }
  .carousel-track-wrapper { overflow: hidden; }
  .carousel-track {
    display: flex;
    gap: 12px;
    scroll-snap-type: x mandatory;
    overflow-x: auto;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
  }
  .carousel-track::-webkit-scrollbar { display: none; }
  .carousel-card {
    flex: 0 0 calc(25% - 9px);
    scroll-snap-align: start;
    position: relative;
    aspect-ratio: 3/4;
    border-radius: var(--vz-radius);
    overflow: hidden;
    transition: transform var(--vz-transition);
    display: block;
    text-decoration: none;
    color: var(--vz-white);
  }
  .carousel-card:hover { transform: scale(1.03); }
  .carousel-card.active { outline: 2px solid var(--vz-accent); outline-offset: 2px; }
  .carousel-card-image { width: 100%; height: 100%; object-fit: cover; }
  .carousel-card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 16px 12px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7));
  }
  .carousel-card-title {
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    font-family: var(--font-heading);
    margin: 0;
  }
  .carousel-card-count {
    font-size: 11px;
    opacity: 0.8;
  }
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--vz-white);
    border: 1px solid var(--vz-border);
    cursor: pointer;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    transition: background var(--vz-transition);
  }
  .carousel-arrow:hover { background: var(--vz-light-gray); }
  .carousel-arrow--prev { left: -20px; }
  .carousel-arrow--next { right: -20px; }
  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 1rem;
  }
  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--vz-border);
    border: none;
    cursor: pointer;
    transition: background var(--vz-transition);
    padding: 0;
  }
  .carousel-dot.active { background: var(--vz-accent); }

  @media (max-width: 989px) { .carousel-card { flex: 0 0 calc(50% - 6px); } }
  @media (max-width: 749px) {
    .carousel-card { flex: 0 0 70%; }
    .carousel-arrow { display: none !important; }
  }
</style>

{% schema %}
{
  "name": "Collections Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP BY COLLECTION"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom label (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Carousel"
    }
  ]
}
{% endschema %}
