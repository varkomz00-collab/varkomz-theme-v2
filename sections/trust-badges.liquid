<section class="apple-trust" id="Trust-{{ section.id }}">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="apple-trust__title">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="apple-trust__grid">
      {% for block in section.blocks %}
        <div class="apple-trust__item" {{ block.shopify_attributes }}>
          <div class="apple-trust__icon">
            {% case block.settings.icon %}
              {% when 'shield' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {% when 'truck' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {% when 'refresh' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
              {% when 'chat' %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {% else %}
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            {% endcase %}
          </div>
          <h3 class="apple-trust__name">{{ block.settings.title }}</h3>
          <p class="apple-trust__desc">{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .apple-trust {
    padding: 80px 0;
    background: var(--vz-light-gray);
  }
  .apple-trust__title {
    text-align: center;
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--vz-black);
    margin: 0 0 56px;
  }
  .apple-trust__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .apple-trust__item {
    text-align: center;
    padding: 40px 24px;
    position: relative;
  }
  .apple-trust__item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 25%;
    height: 50%;
    width: 1px;
    background: var(--vz-border);
  }
  .apple-trust__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--vz-white);
    color: var(--vz-black);
    margin-bottom: 20px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .apple-trust__name {
    font-family: var(--font-heading);
    font-size: 17px;
    font-weight: 600;
    color: var(--vz-black);
    margin: 0 0 8px;
    letter-spacing: -0.01em;
  }
  .apple-trust__desc {
    font-size: 14px;
    color: var(--vz-gray);
    line-height: 1.55;
    margin: 0;
    max-width: 220px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 989px) {
    .apple-trust__grid { grid-template-columns: repeat(2, 1fr); }
    .apple-trust__item:nth-child(2)::after { display: none; }
    .apple-trust__item:nth-child(1)::after,
    .apple-trust__item:nth-child(3)::after { height: 50%; }
  }
  @media (max-width: 734px) {
    .apple-trust { padding: 56px 0; }
    .apple-trust__title { margin-bottom: 36px; }
    .apple-trust__item { padding: 28px 16px; }
    .apple-trust__item::after { display: none !important; }
    .apple-trust__grid { gap: 8px; }
  }
</style>

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Riders Choose Varkomz" }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [
          { "value": "shield", "label": "Shield" }, { "value": "truck", "label": "Truck" },
          { "value": "refresh", "label": "Refresh" }, { "value": "chat", "label": "Chat" },
          { "value": "check", "label": "Check" }
        ], "default": "shield" },
        { "type": "text", "id": "title", "label": "Title", "default": "Authorized Dealer" },
        { "type": "text", "id": "text", "label": "Description", "default": "Official warranty-backed products." }
      ]
    }
  ],
  "presets": [{ "name": "Trust Badges", "blocks": [
    { "type": "badge", "settings": { "icon": "shield", "title": "Authorized Dealer", "text": "Genuine, warranty-backed products." } },
    { "type": "badge", "settings": { "icon": "truck", "title": "Free Shipping", "text": "Same-day dispatch from Doha." } },
    { "type": "badge", "settings": { "icon": "refresh", "title": "14-Day Returns", "text": "Full refund, no questions." } },
    { "type": "badge", "settings": { "icon": "chat", "title": "Expert Support", "text": "Response in under 2 hours." } }
  ] }]
}
{% endschema %}
