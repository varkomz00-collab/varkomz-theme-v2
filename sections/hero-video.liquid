{%- liquid
  assign video_url = section.settings.video_url | default: ''
  assign overlay_opacity = section.settings.overlay_opacity | divided_by: 100.0

  assign is_youtube = false
  assign is_vimeo = false
  assign is_mp4 = false
  assign video_id = ''

  if video_url contains 'youtube.com' or video_url contains 'youtu.be'
    assign is_youtube = true
    if video_url contains 'youtu.be/'
      assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first
    elsif video_url contains 'v='
      assign video_id = video_url | split: 'v=' | last | split: '&' | first
    endif
  elsif video_url contains 'vimeo.com'
    assign is_vimeo = true
    assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | last
  elsif video_url contains '.mp4'
    assign is_mp4 = true
  endif
-%}

<section id="hero-{{ section.id }}" class="hero-apple">
  <div class="hero-apple__media">
    {%- if is_youtube and video_id != '' -%}
      <iframe
        src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&loop=1&playlist={{ video_id }}&controls=0&showinfo=0&rel=0&modestbranding=1&playsinline=1"
        frameborder="0" allow="autoplay; encrypted-media" allowfullscreen
        class="hero-apple__iframe"
      ></iframe>
    {%- elsif is_vimeo and video_id != '' -%}
      <iframe
        src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&loop=1&background=1"
        frameborder="0" allow="autoplay" allowfullscreen
        class="hero-apple__iframe"
      ></iframe>
    {%- elsif is_mp4 -%}
      <video autoplay muted loop playsinline class="hero-apple__video">
        <source src="{{ video_url }}" type="video/mp4">
      </video>
    {%- elsif section.settings.fallback_image != blank -%}
      <img
        src="{{ section.settings.fallback_image | image_url: width: 1920 }}"
        alt="{{ section.settings.title | escape }}"
        loading="eager"
        class="hero-apple__img"
      >
    {%- endif -%}
    <div class="hero-apple__gradient"></div>
    <div class="hero-apple__overlay" style="opacity:{{ overlay_opacity }};"></div>
  </div>

  <div class="hero-apple__content">
    {%- if section.settings.pre_headline != blank -%}
      <p class="hero-apple__eyebrow">{{ section.settings.pre_headline }}</p>
    {%- endif -%}

    {%- if section.settings.title != blank -%}
      <h1 class="hero-apple__title">{{ section.settings.title | newline_to_br }}</h1>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="hero-apple__subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="hero-apple__ctas">
      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link }}" class="hero-apple__cta hero-apple__cta--primary">
          {{ section.settings.link_text }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
      {%- if section.settings.second_link_text != blank -%}
        <a href="{{ section.settings.second_link }}" class="hero-apple__cta hero-apple__cta--ghost">
          {{ section.settings.second_link_text }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  #hero-{{ section.id }} {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    color: #fff;
  }
  #hero-{{ section.id }} .hero-apple__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  #hero-{{ section.id }} .hero-apple__gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 100%);
    z-index: 1;
  }
  #hero-{{ section.id }} .hero-apple__overlay {
    position: absolute;
    inset: 0;
    background: #000;
    z-index: 2;
  }
  #hero-{{ section.id }} .hero-apple__iframe,
  #hero-{{ section.id }} .hero-apple__video,
  #hero-{{ section.id }} .hero-apple__img {
    position: absolute;
    top: 50%; left: 50%;
    min-width: 100%; min-height: 100%;
    width: auto; height: auto;
    transform: translate(-50%, -50%);
    object-fit: cover;
    z-index: 0;
  }
  #hero-{{ section.id }} .hero-apple__iframe {
    width: 110vw; height: 110vh;
    pointer-events: none;
  }
  #hero-{{ section.id }} .hero-apple__content {
    position: relative;
    z-index: 3;
    text-align: center;
    max-width: 820px;
    padding: 0 24px;
  }
  #hero-{{ section.id }} .hero-apple__eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.7;
    margin-bottom: 20px;
  }
  #hero-{{ section.id }} .hero-apple__title {
    font-family: var(--font-heading);
    font-size: clamp(40px, 7vw, 80px);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 24px;
    color: #fff;
  }
  #hero-{{ section.id }} .hero-apple__subtitle {
    font-size: clamp(17px, 2vw, 21px);
    line-height: 1.5;
    opacity: 0.85;
    margin: 0 auto 40px;
    max-width: 560px;
    font-weight: 400;
  }
  #hero-{{ section.id }} .hero-apple__ctas {
    display: flex;
    gap: 20px;
    justify-content: center;
    flex-wrap: wrap;
  }
  #hero-{{ section.id }} .hero-apple__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 32px;
    border-radius: 980px;
    font-size: 17px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
    letter-spacing: -0.01em;
  }
  #hero-{{ section.id }} .hero-apple__cta--primary {
    background: #fff;
    color: var(--vz-black);
  }
  #hero-{{ section.id }} .hero-apple__cta--primary:hover {
    background: rgba(255,255,255,0.88);
  }
  #hero-{{ section.id }} .hero-apple__cta--ghost {
    background: transparent;
    color: #fff;
    border: 1.5px solid rgba(255,255,255,0.35);
  }
  #hero-{{ section.id }} .hero-apple__cta--ghost:hover {
    border-color: rgba(255,255,255,0.7);
    background: rgba(255,255,255,0.08);
  }

  @media (max-width: 734px) {
    #hero-{{ section.id }} { min-height: 520px; }
    #hero-{{ section.id }} .hero-apple__ctas { flex-direction: column; align-items: center; }
    #hero-{{ section.id }} .hero-apple__cta { width: 100%; max-width: 300px; justify-content: center; }
  }
</style>

{% schema %}
{
  "name": "Hero Video",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "video_url", "label": "Video URL", "info": "YouTube, Vimeo, or direct MP4" },
    { "type": "image_picker", "id": "fallback_image", "label": "Fallback image" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 100, "step": 5, "default": 40, "unit": "%", "label": "Overlay opacity" },
    { "type": "text", "id": "pre_headline", "label": "Eyebrow text", "default": "AUTHORIZED DEALER" },
    { "type": "text", "id": "title", "label": "Title", "default": "Your Wave.\nYour Way." },
    { "type": "range", "id": "title_size", "min": 40, "max": 100, "step": 2, "default": 72, "unit": "px", "label": "Title size" },
    { "type": "text", "id": "subheading", "label": "Subtitle", "default": "Premium boats, pro-grade gear, and waterfront apparel." },
    { "type": "text", "id": "link_text", "label": "Primary button", "default": "Shop Best Sellers" },
    { "type": "url", "id": "link", "label": "Primary link" },
    { "type": "text", "id": "second_link_text", "label": "Secondary button", "default": "Explore by Sport" },
    { "type": "url", "id": "second_link", "label": "Secondary link" },
    { "type": "text", "id": "social_proof_text", "label": "Social proof" },
    { "type": "select", "id": "height", "label": "Height", "options": [
      { "value": "100vh", "label": "Full screen" }, { "value": "80vh", "label": "80%" }, { "value": "650px", "label": "650px" }
    ], "default": "100vh" },
    { "type": "select", "id": "text_alignment", "label": "Alignment", "options": [
      { "value": "center", "label": "Center" }, { "value": "left", "label": "Left" }, { "value": "bottom-left", "label": "Bottom left" }
    ], "default": "center" }
  ],
  "presets": [{ "name": "Hero Video" }]
}
{% endschema %}
