<section class="apple-quote" id="Quote-{{ section.id }}">
  <div class="page-width">
    <div class="apple-quote__header">
      {% if section.settings.heading != blank %}
        <h2 class="apple-quote__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="apple-quote__desc">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="apple-quote__card">
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <div class="apple-quote__success">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--vz-green)" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="8 12 11 15 16 9"/></svg>
            <h3>We've received your request.</h3>
            <p>Expect a detailed quote within 2 hours.</p>
          </div>
        {% else %}
          {% if form.errors %}
            <div class="apple-quote__error">{{ form.errors | default_errors }}</div>
          {% endif %}

          <div class="apple-quote__fields">
            <div class="apple-quote__field">
              <input type="text" name="contact[name]" value="{{ form.name | escape }}" required placeholder="Name" class="apple-quote__input">
            </div>
            <div class="apple-quote__field">
              <input type="email" name="contact[email]" value="{{ form.email | escape }}" required placeholder="Email" class="apple-quote__input">
            </div>
            {% if section.settings.show_phone %}
              <div class="apple-quote__field">
                <div style="display:flex;gap:8px;">
                  <select name="contact[country_code]" class="apple-quote__input" style="flex:0 0 90px;padding-right:4px;">
                    <option value="+974">🇶🇦 +974</option>
                    <option value="+971">🇦🇪 +971</option>
                    <option value="+966">🇸🇦 +966</option>
                    <option value="+965">🇰🇼 +965</option>
                    <option value="+973">🇧🇭 +973</option>
                    <option value="+968">🇴🇲 +968</option>
                  </select>
                  <input type="tel" name="contact[phone]" placeholder="Phone number" class="apple-quote__input" style="flex:1;">
                </div>
              </div>
            {% endif %}
            <div class="apple-quote__field apple-quote__field--full">
              <select name="contact[interest]" class="apple-quote__input">
                <option value="" disabled selected>I'm interested in...</option>
                <option value="Tigé Boat">Tigé Boat</option>
                <option value="ATX Boat">ATX Surf Boat</option>
                <option value="Wakeboard Gear">Wakeboard Gear</option>
                <option value="Wakesurf Gear">Wakesurf Gear</option>
                <option value="Life Vests">Life Vests & Safety</option>
                <option value="Apparel">Apparel & Lifestyle</option>
                <option value="Bulk Order">Bulk / Corporate Order</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="apple-quote__field apple-quote__field--full">
              <textarea name="contact[body]" rows="3" required placeholder="Tell us more — model, quantity, timeline..." class="apple-quote__input apple-quote__textarea">{{ form.body | escape }}</textarea>
            </div>
          </div>

          <div class="apple-quote__actions">
            <button type="submit" class="apple-quote__submit">Request Quote</button>
            <a href="https://wa.me/97451835555" target="_blank" rel="noopener" class="apple-quote__wa">
              or WhatsApp us →
            </a>
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

<style>
  .apple-quote {
    padding: 96px 0;
  }
  .apple-quote__header {
    text-align: center;
    max-width: 560px;
    margin: 0 auto 48px;
  }
  .apple-quote__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--vz-black);
    margin: 0 0 16px;
  }
  .apple-quote__desc {
    font-size: 17px;
    color: var(--vz-gray);
    line-height: 1.6;
  }
  .apple-quote__desc p { margin: 0; }
  .apple-quote__card {
    max-width: 640px;
    margin: 0 auto;
    background: var(--vz-light-gray);
    border-radius: 20px;
    padding: 48px 40px;
  }
  .apple-quote__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .apple-quote__field--full {
    grid-column: 1 / -1;
  }
  .apple-quote__input {
    width: 100%;
    padding: 16px 20px;
    border: 1px solid var(--vz-border);
    border-radius: 12px;
    background: var(--vz-white);
    font-size: 16px;
    font-family: inherit;
    color: var(--vz-black);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .apple-quote__input:focus {
    border-color: var(--vz-accent);
    box-shadow: 0 0 0 3px rgba(0,113,227,0.12);
  }
  .apple-quote__input::placeholder {
    color: var(--vz-gray);
    opacity: 0.7;
  }
  .apple-quote__textarea {
    resize: vertical;
    min-height: 100px;
  }
  .apple-quote__actions {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-top: 20px;
  }
  .apple-quote__submit {
    padding: 16px 40px;
    border: none;
    border-radius: 980px;
    background: var(--vz-black);
    color: var(--vz-white);
    font-size: 17px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .apple-quote__submit:hover { opacity: 0.85; }
  .apple-quote__wa {
    font-size: 15px;
    color: var(--vz-accent);
    text-decoration: none;
    font-weight: 500;
  }
  .apple-quote__wa:hover { text-decoration: underline; }
  .apple-quote__success {
    text-align: center;
    padding: 24px 0;
  }
  .apple-quote__success h3 {
    font-family: var(--font-heading);
    font-size: 24px;
    margin: 20px 0 8px;
  }
  .apple-quote__success p {
    color: var(--vz-gray);
    font-size: 17px;
  }
  .apple-quote__error {
    background: #FEF2F2;
    border: 1px solid #FCA5A5;
    border-radius: 12px;
    padding: 12px 16px;
    margin-bottom: 16px;
    color: #DC2626;
    font-size: 14px;
  }

  @media (max-width: 734px) {
    .apple-quote { padding: 64px 0; }
    .apple-quote__card { padding: 32px 20px; }
    .apple-quote__fields { grid-template-columns: 1fr; }
    .apple-quote__actions { flex-direction: column; gap: 16px; }
    .apple-quote__submit { width: 100%; }
  }
</style>

{% schema %}
{
  "name": "Contact / Quote",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Request a Quote" },
    { "type": "richtext", "id": "text", "label": "Description", "default": "<p>Tell us what you're looking for. Detailed quote with pricing and delivery timeline within 2 hours.</p>" },
    { "type": "checkbox", "id": "show_phone", "label": "Show phone field", "default": true }
  ],
  "presets": [{ "name": "Contact / Quote" }]
}
{% endschema %}
