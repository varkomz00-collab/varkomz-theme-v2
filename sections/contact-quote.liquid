<section class="contact-quote-section" id="ContactQuote-{{ section.id }}">
  <div class="page-width">
    <div class="contact-quote__grid">
      <div class="contact-quote__content">
        {% if section.settings.heading != blank %}
          <h2 class="contact-quote__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.text != blank %}
          <div class="contact-quote__text rte">{{ section.settings.text }}</div>
        {% endif %}

        <div class="contact-quote__whatsapp">
          <a href="https://wa.me/97451835555" target="_blank" rel="noopener" class="btn btn-outline contact-quote__wa-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right:8px;vertical-align:middle;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Or WhatsApp us for instant response
          </a>
        </div>
      </div>

      <div class="contact-quote__form-col">
        {% form 'contact' %}
          {% if form.posted_successfully? %}
            <div class="contact-quote__success">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--vz-green)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <h3>Quote Request Received!</h3>
              <p>We'll get back to you within 2 hours.</p>
            </div>
          {% else %}
            {% if form.errors %}
              <div class="contact-quote__errors">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="form-group">
              <label for="ContactName-{{ section.id }}">Name</label>
              <input type="text" id="ContactName-{{ section.id }}" name="contact[name]" value="{{ form.name | escape }}" required class="form-input">
            </div>

            <div class="form-group">
              <label for="ContactEmail-{{ section.id }}">Email</label>
              <input type="email" id="ContactEmail-{{ section.id }}" name="contact[email]" value="{{ form.email | escape }}" required class="form-input">
            </div>

            {% if section.settings.show_phone %}
              <div class="form-group">
                <label for="ContactPhone-{{ section.id }}">Phone</label>
                <input type="tel" id="ContactPhone-{{ section.id }}" name="contact[phone]" value="" class="form-input">
              </div>
            {% endif %}

            <div class="form-group">
              <label for="ContactMessage-{{ section.id }}">What are you looking for?</label>
              <textarea id="ContactMessage-{{ section.id }}" name="contact[body]" rows="4" required class="form-input">{{ form.body | escape }}</textarea>
            </div>

            <button type="submit" class="btn btn-primary contact-quote__submit">Request Quote</button>
            <p class="contact-quote__commitment">We'll get back to you within 2 hours</p>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-quote-section {
    padding: 5rem 0;
    background: var(--vz-light-gray);
  }
  .contact-quote__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }
  .contact-quote__heading {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--vz-black);
    margin-bottom: 1rem;
  }
  .contact-quote__text {
    color: var(--vz-gray);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .contact-quote__wa-btn {
    display: inline-flex;
    align-items: center;
  }
  .contact-quote__form-col {
    background: var(--vz-white);
    padding: 2rem;
    border-radius: var(--vz-radius);
    border: 1px solid var(--vz-border);
  }
  .contact-quote__submit {
    width: 100%;
    margin-top: 0.5rem;
  }
  .contact-quote__commitment {
    text-align: center;
    font-size: 0.8125rem;
    color: var(--vz-gray);
    margin-top: 0.75rem;
  }
  .contact-quote__success {
    text-align: center;
    padding: 2rem 0;
  }
  .contact-quote__success h3 {
    margin: 1rem 0 0.5rem;
    font-family: var(--font-heading);
  }
  .contact-quote__success p {
    color: var(--vz-gray);
  }
  .contact-quote__errors {
    background: #fff5f5;
    border: 1px solid var(--vz-sale);
    border-radius: var(--vz-radius-sm);
    padding: 1rem;
    margin-bottom: 1rem;
    color: var(--vz-sale);
    font-size: 0.875rem;
  }
  @media (max-width: 989px) {
    .contact-quote__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>

{% schema %}
{
  "name": "Contact / Quote",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Request a Quote"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Tell us what you're looking for and we'll send a detailed quote with pricing, delivery timeline, and financing options.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone field",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Contact / Quote"
    }
  ]
}
{% endschema %}
