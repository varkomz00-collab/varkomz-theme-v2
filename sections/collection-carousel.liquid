<section id="collection-carousel-{{ section.id }}" class="collection-carousel">
  <div class="collection-carousel__wrapper">
    <div class="collection-carousel__track">
      {%- for block in section.blocks -%}
        {%- liquid
          assign col = block.settings.collection
          assign label = block.settings.label | default: col.title
          assign is_active = false
          if collection and col and collection.handle == col.handle
            assign is_active = true
          endif
        -%}
        <a
          href="{{ col.url | default: '#' }}"
          class="collection-carousel__card{% if is_active %} collection-carousel__card--active{% endif %}"
          {{ block.shopify_attributes }}
        >
          {%- if col.featured_image != blank -%}
            <div class="collection-carousel__image-wrapper">
              <img
                src="{{ col.featured_image | image_url: width: 300, height: 400, crop: 'center' }}"
                alt="{{ label | escape }}"
                width="150"
                height="200"
                loading="lazy"
                class="collection-carousel__image"
              >
            </div>
          {%- else -%}
            <div class="collection-carousel__image-wrapper">
              <div class="collection-carousel__placeholder">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            </div>
          {%- endif -%}
          <span class="collection-carousel__label">{{ label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  #collection-carousel-{{ section.id }} {
    padding: 40px 0;
    overflow: hidden;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__track {
    display: flex;
    gap: 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding-bottom: 8px;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__track::-webkit-scrollbar {
    display: none;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__card {
    flex: 0 0 auto;
    width: 140px;
    scroll-snap-align: start;
    text-decoration: none;
    color: #1d1d1f;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 12px;
    border-radius: 14px;
    transition: all 0.3s ease;
    background: #f5f5f7;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__card:hover {
    background: #e8e8ed;
    transform: translateY(-2px);
  }

  #collection-carousel-{{ section.id }} .collection-carousel__card--active {
    background: #0a1628;
    color: #fff;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__card--active:hover {
    background: #1a3a5c;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__image-wrapper {
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 10px;
    overflow: hidden;
    background: #e5e5ea;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__placeholder svg {
    width: 100%;
    height: auto;
    opacity: 0.3;
  }

  #collection-carousel-{{ section.id }} .collection-carousel__label {
    font-size: 13px;
    font-weight: 600;
    text-align: center;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  @media (max-width: 768px) {
    #collection-carousel-{{ section.id }} .collection-carousel__card {
      width: 110px;
      padding: 10px;
    }
    #collection-carousel-{{ section.id }} .collection-carousel__label {
      font-size: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "Collection Carousel",
  "tag": "section",
  "class": "section-collection-carousel",
  "settings": [],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Custom label",
          "info": "Leave blank to use the collection title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Carousel"
    }
  ]
}
{% endschema %}
