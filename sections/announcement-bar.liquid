{%- liquid
  assign bg_color = section.settings.bg_color | default: '#0a1628'
  assign text_color = section.settings.text_color | default: '#ffffff'
  assign link = section.settings.link

  assign messages = '' | split: ','
  if section.settings.text_1 != blank
    assign messages = messages | append: section.settings.text_1 | append: '|||'
  endif
  if section.settings.text_2 != blank
    assign messages = messages | append: section.settings.text_2 | append: '|||'
  endif
  if section.settings.text_3 != blank
    assign messages = messages | append: section.settings.text_3 | append: '|||'
  endif
  assign messages_array = messages | split: '|||'
  assign message_count = messages_array.size
-%}

{%- if message_count > 0 -%}
<section
  id="announcement-bar-{{ section.id }}"
  class="announcement-bar"
  style="--ab-bg: {{ bg_color }}; --ab-color: {{ text_color }}; --message-count: {{ message_count }};"
  role="region"
  aria-label="Announcement"
>
  {%- if link != blank -%}<a href="{{ link }}" class="announcement-bar__link">{%- endif -%}

  <div class="announcement-bar__track">
    {%- for msg in messages_array -%}
      {%- if msg != blank -%}
        <div class="announcement-bar__message" {% if message_count > 1 %}style="animation-delay: {{ forloop.index0 | times: 4 }}s;"{% endif %}>
          <p>{{ msg }}</p>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if link != blank -%}</a>{%- endif -%}
</section>
{%- endif -%}

<style>
  {%- if message_count > 1 -%}
    {%- assign total_dur = message_count | times: 4 -%}
    {%- assign visible_pct = 100.0 | divided_by: message_count -%}
    {%- assign fade_in_end = visible_pct | times: 0.1 -%}
    {%- assign visible_end = visible_pct | times: 0.85 -%}
    {%- assign fade_out_end = visible_pct -%}

    @keyframes announcement-rotate-{{ section.id }} {
      0% { opacity: 0; visibility: hidden; }
      {{ fade_in_end }}% { opacity: 1; visibility: visible; }
      {{ visible_end }}% { opacity: 1; visibility: visible; }
      {{ fade_out_end }}% { opacity: 0; visibility: hidden; }
      100% { opacity: 0; visibility: hidden; }
    }
  {%- endif -%}

  #announcement-bar-{{ section.id }} {
    background: var(--ab-bg);
    color: var(--ab-color);
    text-align: center;
    position: relative;
    overflow: hidden;
    min-height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #announcement-bar-{{ section.id }} .announcement-bar__link {
    text-decoration: none;
    color: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 40px;
  }

  #announcement-bar-{{ section.id }} .announcement-bar__track {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
  }

  #announcement-bar-{{ section.id }} .announcement-bar__message {
    padding: 10px 20px;
  }

  #announcement-bar-{{ section.id }} .announcement-bar__message p {
    margin: 0;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1.4;
  }

  {%- if message_count > 1 -%}
    #announcement-bar-{{ section.id }} .announcement-bar__message {
      position: absolute;
      opacity: 0;
      visibility: hidden;
      animation: announcement-rotate-{{ section.id }} {{ total_dur }}s infinite;
    }
  {%- endif -%}

  @media (prefers-reduced-motion: reduce) {
    #announcement-bar-{{ section.id }} .announcement-bar__message {
      animation: none !important;
      position: relative !important;
      opacity: 1 !important;
      visibility: visible !important;
    }
    #announcement-bar-{{ section.id }} .announcement-bar__message:not(:first-child) {
      display: none;
    }
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "text",
      "id": "text_1",
      "label": "Message 1",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Message 2",
      "default": "New arrivals just dropped"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Message 3"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0a1628"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
