{%- liquid
  assign messages = '' | split: ','
  for block in section.blocks
    if block.settings.text != blank
      assign messages = messages | push: block.settings.text
    endif
  endfor
  assign message_count = messages.size
-%}

{%- if message_count > 0 -%}
<div
  id="announcement-bar-{{ section.id }}"
  class="announcement-bar"
  role="region"
  aria-label="Announcement"
>
  <div class="announcement-bar__track">
    {%- for msg in messages -%}
      <div class="announcement-bar__slide{% if forloop.first %} announcement-bar__slide--active{% endif %}">
        <p>{{ msg }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>
{%- endif -%}

<style>
  #announcement-bar-{{ section.id }} {
    background: var(--vz-black);
    color: var(--vz-white);
    text-align: center;
    position: relative;
    overflow: hidden;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #announcement-bar-{{ section.id }} .announcement-bar__track {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #announcement-bar-{{ section.id }} .announcement-bar__slide {
    position: absolute;
    width: 100%;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  #announcement-bar-{{ section.id }} .announcement-bar__slide--active {
    opacity: 1;
  }
  #announcement-bar-{{ section.id }} p {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    line-height: 36px;
  }
  @media (prefers-reduced-motion: reduce) {
    #announcement-bar-{{ section.id }} .announcement-bar__slide {
      transition: none;
    }
  }
</style>

<script>
  (function() {
    var bar = document.getElementById('announcement-bar-{{ section.id }}');
    if (!bar) return;
    var slides = bar.querySelectorAll('.announcement-bar__slide');
    if (slides.length <= 1) return;
    var current = 0;
    setInterval(function() {
      slides[current].classList.remove('announcement-bar__slide--active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('announcement-bar__slide--active');
    }, 4000);
  })();
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "settings": [],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Message text",
          "default": "Free shipping on all orders"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "blocks": [
        { "type": "message", "settings": { "text": "Free shipping on all orders" } }
      ]
    }
  ]
}
{% endschema %}
