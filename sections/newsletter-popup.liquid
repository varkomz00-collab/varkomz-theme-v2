<div id="NewsletterPopup" class="newsletter-popup" data-delay="{{ section.settings.delay | times: 1000 }}">
  <div class="newsletter-popup-overlay"></div>
  <div class="newsletter-popup-modal">
    <button class="newsletter-popup-close" aria-label="Close popup">&times;</button>

    {% if section.settings.title != blank %}
      <h2 class="newsletter-popup-title">{{ section.settings.title }}</h2>
    {% endif %}

    {% if section.settings.text != blank %}
      <p class="newsletter-popup-text">{{ section.settings.text }}</p>
    {% endif %}

    {% form 'customer', id: 'NewsletterForm' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-popup-field">
        <input
          type="email"
          name="contact[email]"
          placeholder="{{ section.settings.placeholder | default: 'Enter your email' }}"
          required
          aria-label="Email address"
          class="newsletter-popup-input"
        >
        <button type="submit" class="btn btn-primary newsletter-popup-submit">
          {{ section.settings.button_label | default: 'Subscribe' }}
        </button>
      </div>
    {% endform %}

    {% if section.settings.disclaimer != blank %}
      <p class="newsletter-popup-disclaimer">{{ section.settings.disclaimer }}</p>
    {% endif %}
  </div>
</div>

<style>
  .newsletter-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 10000;
    align-items: center;
    justify-content: center;
  }
  .newsletter-popup.active {
    display: flex;
  }
  .newsletter-popup-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
  }
  .newsletter-popup-modal {
    position: relative;
    background: var(--vz-white, #fff);
    border-radius: var(--vz-radius, 14px);
    padding: 3rem 2.5rem;
    max-width: 480px;
    width: 90%;
    text-align: center;
    box-shadow: var(--vz-shadow-lg, 0 8px 30px rgba(0,0,0,0.12));
  }
  .newsletter-popup-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    font-size: 1.75rem;
    cursor: pointer;
    color: var(--vz-gray, #6e6e73);
    line-height: 1;
  }
  .newsletter-popup-close:hover {
    color: var(--vz-black, #1d1d1f);
  }
  .newsletter-popup-title {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .newsletter-popup-text {
    color: var(--vz-gray, #6e6e73);
    margin-bottom: 1.5rem;
    font-size: 15px;
    line-height: 1.6;
  }
  .newsletter-popup-field {
    display: flex;
    gap: 8px;
  }
  .newsletter-popup-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--vz-border, #e8e8ed);
    border-radius: 980px;
    font-size: 15px;
    outline: none;
  }
  .newsletter-popup-input:focus {
    border-color: var(--vz-accent, #0071e3);
    box-shadow: 0 0 0 3px rgba(0, 113, 227, 0.1);
  }
  .newsletter-popup-submit {
    white-space: nowrap;
    border-radius: 980px;
    padding: 12px 24px;
  }
  .newsletter-popup-disclaimer {
    font-size: 12px;
    color: var(--vz-gray-secondary, #86868b);
    margin-top: 1rem;
    line-height: 1.4;
  }
  @media (max-width: 480px) {
    .newsletter-popup-modal {
      padding: 2rem 1.5rem;
    }
    .newsletter-popup-field {
      flex-direction: column;
    }
  }
</style>

{% schema %}
{
  "name": "Newsletter Popup",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join the Crew"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Get 10% off your first order, plus early access to new arrivals and exclusive deals."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button text",
      "default": "Get 10% Off"
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "No spam, ever. Unsubscribe anytime."
    },
    {
      "type": "range",
      "id": "delay",
      "label": "Show after (seconds)",
      "min": 1,
      "max": 30,
      "step": 1,
      "default": 5,
      "unit": "s"
    }
  ]
}
{% endschema %}
