{%- liquid
  assign text = section.settings.text | default: 'Free shipping on all orders'
  assign text_size = section.settings.text_size | default: 16
  assign speed = section.settings.speed | default: 200
  assign direction = section.settings.direction | default: 'left'
  assign link = section.settings.link
  assign animation_duration = speed | times: 0.1
-%}

<section id="scrolling-text-{{ section.id }}" class="scrolling-text">
  {%- if link != blank -%}
    <a href="{{ link }}" class="scrolling-text__link">
  {%- endif -%}

  <div class="scrolling-text__track" style="--duration: {{ animation_duration }}s; --font-size: {{ text_size }}px;">
    <div class="scrolling-text__inner scrolling-text__inner--{{ direction }}">
      {%- for i in (1..20) -%}
        <span class="scrolling-text__item">{{ text }}</span>
        <span class="scrolling-text__separator" aria-hidden="true">&nbsp;&bull;&nbsp;</span>
      {%- endfor -%}
    </div>
    <div class="scrolling-text__inner scrolling-text__inner--{{ direction }}" aria-hidden="true">
      {%- for i in (1..20) -%}
        <span class="scrolling-text__item">{{ text }}</span>
        <span class="scrolling-text__separator" aria-hidden="true">&nbsp;&bull;&nbsp;</span>
      {%- endfor -%}
    </div>
  </div>

  {%- if link != blank -%}
    </a>
  {%- endif -%}
</section>

<style>
  @keyframes scrolling-text-left-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-100%); }
  }

  @keyframes scrolling-text-right-{{ section.id }} {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(0); }
  }

  #scrolling-text-{{ section.id }} {
    overflow: hidden;
    padding: 12px 0;
    background: #000;
    color: #fff;
  }

  #scrolling-text-{{ section.id }} .scrolling-text__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  #scrolling-text-{{ section.id }} .scrolling-text__track {
    display: flex;
    width: max-content;
  }

  #scrolling-text-{{ section.id }} .scrolling-text__inner {
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }

  #scrolling-text-{{ section.id }} .scrolling-text__inner--left {
    animation: scrolling-text-left-{{ section.id }} var(--duration) linear infinite;
  }

  #scrolling-text-{{ section.id }} .scrolling-text__inner--right {
    animation: scrolling-text-right-{{ section.id }} var(--duration) linear infinite;
  }

  #scrolling-text-{{ section.id }} .scrolling-text__item {
    font-size: var(--font-size);
    font-weight: 800;
    letter-spacing: -0.03em;
    text-transform: uppercase;
  }

  #scrolling-text-{{ section.id }} .scrolling-text__separator {
    font-size: var(--font-size);
    opacity: 0.4;
    margin: 0 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    #scrolling-text-{{ section.id }} .scrolling-text__inner {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "Scrolling Text",
  "tag": "section",
  "class": "section-scrolling-text",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Free shipping on all orders"
    },
    {
      "type": "range",
      "id": "text_size",
      "min": 12,
      "max": 100,
      "step": 1,
      "default": 16,
      "unit": "px",
      "label": "Font size"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 50,
      "max": 300,
      "step": 10,
      "default": 200,
      "label": "Speed",
      "info": "Higher = slower"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Scrolling Text"
    }
  ]
}
{% endschema %}
