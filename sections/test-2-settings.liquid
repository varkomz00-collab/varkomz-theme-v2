<div style="background: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; padding: 40px; text-align: center; margin: 2rem 0;">
  <h2 style="font-size: 2rem; margin-bottom: 1rem;">✅ TEST 2: {{ section.settings.heading }}</h2>
  <p style="font-size: 1.125rem;">{{ section.settings.message }}</p>
  <small style="opacity: 0.8;">If you see a blue background with the custom text above, settings wiring works.</small>
</div>

{% schema %}
{
  "name": "Test 2 - Settings",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "SETTINGS TEST" },
    { "type": "text", "id": "message", "label": "Message", "default": "Default message" },
    { "type": "color", "id": "bg_color", "label": "Background", "default": "#3b82f6" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Test 2 - Settings" }]
}
{% endschema %}
