<section id="contact-form-{{ section.id }}" class="contact-form">
  <div class="contact-form__wrapper page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="contact-form__heading">{{ section.settings.title }}</h2>
    {%- endif -%}

    {%- if section.settings.text != blank -%}
      <div class="contact-form__description rte">{{ section.settings.text }}</div>
    {%- endif -%}

    {%- form 'contact' -%}
      {%- if form.posted_successfully? -%}
        <div class="contact-form__success">
          <p>Thank you for your message. We will get back to you shortly.</p>
        </div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="contact-form__errors">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="contact-form__fields">
        <div class="contact-form__field">
          <label for="contact-name-{{ section.id }}" class="contact-form__label">Name</label>
          <input
            type="text"
            id="contact-name-{{ section.id }}"
            name="contact[name]"
            value="{{ form.name | escape }}"
            placeholder="Your name"
            required
            class="contact-form__input"
          >
        </div>

        <div class="contact-form__field">
          <label for="contact-email-{{ section.id }}" class="contact-form__label">Email</label>
          <input
            type="email"
            id="contact-email-{{ section.id }}"
            name="contact[email]"
            value="{{ form.email }}"
            placeholder="your@email.com"
            required
            autocomplete="email"
            class="contact-form__input"
          >
        </div>

        {%- if section.settings.show_phone -%}
          <div class="contact-form__field">
            <label for="contact-phone-{{ section.id }}" class="contact-form__label">Phone <span class="contact-form__optional">(optional)</span></label>
            <input
              type="tel"
              id="contact-phone-{{ section.id }}"
              name="contact[phone]"
              value="{{ form.phone }}"
              placeholder="+1 (555) 000-0000"
              autocomplete="tel"
              class="contact-form__input"
            >
          </div>
        {%- endif -%}

        <div class="contact-form__field contact-form__field--full">
          <label for="contact-message-{{ section.id }}" class="contact-form__label">Message</label>
          <textarea
            id="contact-message-{{ section.id }}"
            name="contact[body]"
            placeholder="How can we help?"
            rows="5"
            required
            class="contact-form__textarea"
          >{{ form.body | escape }}</textarea>
        </div>
      </div>

      <button type="submit" class="contact-form__submit">
        Send Message
      </button>
    {%- endform -%}
  </div>
</section>

<style>
  #contact-form-{{ section.id }} {
    padding: 80px 0;
  }

  #contact-form-{{ section.id }} .contact-form__wrapper {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 20px;
  }

  #contact-form-{{ section.id }} .contact-form__heading {
    text-align: center;
    font-size: 36px;
    font-weight: 700;
    margin: 0 0 16px;
    letter-spacing: -0.02em;
  }

  #contact-form-{{ section.id }} .contact-form__description {
    text-align: center;
    font-size: 16px;
    line-height: 1.6;
    color: #6e6e73;
    margin: 0 0 40px;
  }

  #contact-form-{{ section.id }} .contact-form__success {
    background: #d4edda;
    color: #155724;
    padding: 16px 20px;
    border-radius: 10px;
    margin-bottom: 24px;
    font-size: 15px;
  }

  #contact-form-{{ section.id }} .contact-form__success p {
    margin: 0;
  }

  #contact-form-{{ section.id }} .contact-form__errors {
    background: #f8d7da;
    color: #721c24;
    padding: 16px 20px;
    border-radius: 10px;
    margin-bottom: 24px;
    font-size: 15px;
  }

  #contact-form-{{ section.id }} .contact-form__fields {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 24px;
  }

  #contact-form-{{ section.id }} .contact-form__field--full {
    grid-column: 1 / -1;
  }

  #contact-form-{{ section.id }} .contact-form__label {
    display: block;
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 6px;
    color: #1d1d1f;
  }

  #contact-form-{{ section.id }} .contact-form__optional {
    font-weight: 400;
    color: #8e8e93;
  }

  #contact-form-{{ section.id }} .contact-form__input,
  #contact-form-{{ section.id }} .contact-form__textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid #d2d2d7;
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    background: #fff;
    color: #1d1d1f;
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }

  #contact-form-{{ section.id }} .contact-form__input:focus,
  #contact-form-{{ section.id }} .contact-form__textarea:focus {
    outline: none;
    border-color: #0d4f8b;
    box-shadow: 0 0 0 3px rgba(13, 79, 139, 0.15);
  }

  #contact-form-{{ section.id }} .contact-form__textarea {
    resize: vertical;
    min-height: 120px;
  }

  #contact-form-{{ section.id }} .contact-form__submit {
    display: inline-block;
    padding: 14px 48px;
    border: none;
    border-radius: 999px;
    background: #0a1628;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
  }

  #contact-form-{{ section.id }} .contact-form__submit:hover {
    background: #1a3a5c;
    transform: translateY(-2px);
  }

  @media (max-width: 600px) {
    #contact-form-{{ section.id }} .contact-form__fields {
      grid-template-columns: 1fr;
    }
    #contact-form-{{ section.id }} .contact-form__heading {
      font-size: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "Contact Form",
  "tag": "section",
  "class": "section-contact-form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Get in Touch"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Have a question or need help? Send us a message and we will respond within 24 hours.</p>"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show phone field",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
