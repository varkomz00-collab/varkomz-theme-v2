<section class="apple-newsletter" id="Newsletter-{{ section.id }}">
  <div class="page-width">
    <div class="apple-newsletter__inner">
      {% if section.settings.heading != blank %}
        <h2 class="apple-newsletter__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="apple-newsletter__subtitle">{{ section.settings.subtitle }}</p>
      {% endif %}

      {% form 'customer', id: 'NewsletterInline' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {% if form.posted_successfully? %}
          <p class="apple-newsletter__success">Welcome aboard. Check your inbox.</p>
        {% else %}
          <div class="apple-newsletter__form">
            <input
              type="email"
              name="contact[email]"
              placeholder="you@email.com"
              required
              class="apple-newsletter__input"
              aria-label="Email"
            >
            <button type="submit" class="apple-newsletter__btn">Subscribe</button>
          </div>
          {% if form.errors %}
            <p class="apple-newsletter__error">{{ form.errors.messages['email'] }}</p>
          {% endif %}
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

<style>
  .apple-newsletter {
    padding: 96px 0;
    background: var(--vz-black);
    color: var(--vz-white);
  }
  .apple-newsletter__inner {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
  }
  .apple-newsletter__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.025em;
    margin: 0 0 12px;
    color: var(--vz-white);
  }
  .apple-newsletter__subtitle {
    font-size: 17px;
    opacity: 0.7;
    margin: 0 0 40px;
    line-height: 1.5;
  }
  .apple-newsletter__form {
    display: flex;
    gap: 12px;
  }
  .apple-newsletter__input {
    flex: 1;
    padding: 16px 24px;
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 980px;
    background: transparent;
    color: var(--vz-white);
    font-size: 16px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .apple-newsletter__input::placeholder {
    color: rgba(255,255,255,0.4);
  }
  .apple-newsletter__input:focus {
    border-color: rgba(255,255,255,0.6);
  }
  .apple-newsletter__btn {
    padding: 16px 32px;
    border: none;
    border-radius: 980px;
    background: var(--vz-white);
    color: var(--vz-black);
    font-size: 16px;
    font-weight: 600;
    font-family: inherit;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }
  .apple-newsletter__btn:hover { opacity: 0.88; }
  .apple-newsletter__success {
    font-size: 18px;
    font-weight: 600;
    color: var(--vz-green);
  }
  .apple-newsletter__error {
    font-size: 13px;
    color: #FCA5A5;
    margin-top: 8px;
  }

  @media (max-width: 734px) {
    .apple-newsletter { padding: 64px 0; }
    .apple-newsletter__form { flex-direction: column; }
    .apple-newsletter__btn { width: 100%; }
  }
</style>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Join the Crew" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Get exclusive drops, deals, and Gulf riding content." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
