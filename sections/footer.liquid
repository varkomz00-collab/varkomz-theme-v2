<footer class="site-footer">
  <div class="footer-wrapper page-width">
    <div class="footer-grid">
      {%- comment -%}Brand column{%- endcomment -%}
      <div class="footer-column footer-column--brand">
        <h4 class="footer-logo-text">{{ shop.name }}</h4>
        <p class="footer-tagline">Qatar's authorized dealer for Tigé, ATX, Hyperlite & HO Sports. Premium boats and gear for Gulf riders.</p>
        <div class="footer-contact-block">
          <p><strong>WhatsApp:</strong> <a href="https://wa.me/97451835555">+974 5183 5555</a></p>
          <p><strong>Email:</strong> <a href="mailto:info@varkomz.com">info@varkomz.com</a></p>
          <p><strong>Location:</strong> Doha, Qatar</p>
        </div>
      </div>

      {%- comment -%}Shop column{%- endcomment -%}
      <div class="footer-column">
        <h4>Shop</h4>
        <ul>
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/collections/all">Wakeboards</a></li>
          <li><a href="/collections/all">Life Vests</a></li>
          <li><a href="/collections/all">Apparel</a></li>
          <li><a href="/collections/all">Accessories</a></li>
          <li><a href="/collections/all">Sale</a></li>
        </ul>
      </div>

      {%- comment -%}Brands column{%- endcomment -%}
      <div class="footer-column">
        <h4>Brands</h4>
        <ul>
          <li><a href="/collections/all">Tigé Boats</a></li>
          <li><a href="/collections/all">ATX Surf Boats</a></li>
          <li><a href="/collections/all">Hyperlite</a></li>
          <li><a href="/collections/all">HO Sports</a></li>
        </ul>
      </div>

      {%- comment -%}Support column{%- endcomment -%}
      <div class="footer-column">
        <h4>Support</h4>
        <ul>
          <li><a href="/pages/contact">Contact Us</a></li>
          <li><a href="/pages/contact">Request a Quote</a></li>
          <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
          <li><a href="/policies/refund-policy">Returns & Refunds</a></li>
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
        </ul>
      </div>
    </div>

    {%- comment -%}Social + Payment + Copyright{%- endcomment -%}
    <div class="footer-bottom">
      <div class="footer-bottom__left">
        <div class="footer-social">
          {% if settings.social_instagram != blank %}
            <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_twitter != blank %}
            <a href="{{ settings.social_twitter }}" target="_blank" rel="noopener" aria-label="X / Twitter">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {% endif %}
          {% if settings.social_tiktok != blank %}
            <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V8.87a8.16 8.16 0 004.76 1.52v-3.4a4.85 4.85 0 01-1-.3z"/></svg>
            </a>
          {% endif %}
        </div>
        <p class="footer-copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
      </div>

      <div class="footer-bottom__right">
        <div class="footer-payments">
          <span class="footer-payments__label">Secure payments</span>
          <div class="footer-payments__icons">
            {%- comment -%}Payment method SVG icons{%- endcomment -%}
            <svg width="38" height="24" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#1A1F71"/><text x="19" y="15" text-anchor="middle" fill="white" font-size="8" font-weight="700" font-family="Arial">VISA</text></svg>
            <svg width="38" height="24" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#252525"/><circle cx="15" cy="12" r="7" fill="#EB001B"/><circle cx="23" cy="12" r="7" fill="#F79E1B"/><path d="M19 7.5a7 7 0 010 9" fill="#FF5F00"/></svg>
            <svg width="38" height="24" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#000"/><text x="19" y="15" text-anchor="middle" fill="white" font-size="7" font-weight="600" font-family="Arial">AMEX</text></svg>
            <svg width="38" height="24" viewBox="0 0 38 24" fill="none"><rect width="38" height="24" rx="4" fill="#5A31F4"/><text x="19" y="15" text-anchor="middle" fill="white" font-size="7" font-weight="600" font-family="Arial">Shop</text></svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--vz-black);
    color: rgba(255,255,255,0.7);
    padding: 64px 0 32px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }
  .footer-logo-text {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 700;
    color: var(--vz-white);
    margin: 0 0 12px;
  }
  .footer-tagline {
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 20px;
    max-width: 280px;
  }
  .footer-contact-block p {
    font-size: 13px;
    margin-bottom: 6px;
  }
  .footer-contact-block a {
    color: rgba(255,255,255,0.9);
    text-decoration: none;
  }
  .footer-contact-block a:hover { color: var(--vz-white); }
  .footer-contact-block strong { color: rgba(255,255,255,0.5); font-weight: 500; }
  .footer-column h4 {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.4);
    margin: 0 0 16px;
  }
  .footer-column ul { list-style: none; padding: 0; margin: 0; }
  .footer-column li { margin-bottom: 10px; }
  .footer-column a {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .footer-column a:hover { color: var(--vz-white); }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 24px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .footer-bottom__left { display: flex; align-items: center; gap: 24px; }
  .footer-social { display: flex; gap: 16px; }
  .footer-social a { color: rgba(255,255,255,0.5); transition: color 0.15s ease; }
  .footer-social a:hover { color: var(--vz-white); }
  .footer-copyright { font-size: 12px; color: rgba(255,255,255,0.35); margin: 0; }
  .footer-payments { display: flex; align-items: center; gap: 12px; }
  .footer-payments__label { font-size: 11px; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.05em; }
  .footer-payments__icons { display: flex; gap: 6px; }

  @media (max-width: 989px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 734px) {
    .footer-grid { grid-template-columns: 1fr; gap: 28px; }
    .footer-bottom { flex-direction: column; align-items: flex-start; }
    .footer-bottom__left { flex-direction: column; align-items: flex-start; gap: 12px; }
    .site-footer { padding: 48px 0 24px; }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
