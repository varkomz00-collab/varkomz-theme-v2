<div style="background: #f59e0b; padding: 40px; margin: 2rem 0;">
  <h2 style="text-align: center; margin-bottom: 1rem; color: #1a1a1a;">✅ TEST 3: Blocks ({{ section.blocks.size }} items)</h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; max-width: 800px; margin: 0 auto;">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'card' %}
          <div style="background: white; padding: 20px; border-radius: 8px; color: #1a1a1a;" {{ block.shopify_attributes }}>
            <h3 style="margin-bottom: 0.5rem;">{{ block.settings.title }}</h3>
            <p>{{ block.settings.description }}</p>
          </div>
      {% endcase %}
    {% endfor %}
  </div>
  <p style="text-align: center; margin-top: 1rem; color: #1a1a1a;"><small>If you see {{ section.blocks.size }} white cards on amber, blocks wiring works.</small></p>
</div>

{% schema %}
{
  "name": "Test 3 - Blocks",
  "settings": [],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Card Title" },
        { "type": "text", "id": "description", "label": "Description", "default": "Card description" }
      ]
    }
  ],
  "presets": [{ "name": "Test 3 - Blocks", "blocks": [{ "type": "card" }] }]
}
{% endschema %}
