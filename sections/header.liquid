{%- assign main_menu = linklists[section.settings.menu] -%}

<header class="site-header" data-section-id="{{ section.id }}">
  <div class="header-wrapper page-width">
    <!-- Mobile menu toggle -->
    <button class="mobile-menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="MobileNav">
      <svg class="icon-hamburger" width="24" height="24" viewBox="0 0 24 24" fill="none">
        <line x1="3" y1="7" x2="21" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="3" y1="12" x2="21" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="3" y1="17" x2="21" y2="17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" style="display:none;">
        <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>

    <a href="/" class="header-logo">
      {% if section.settings.logo %}
        <img
          src="{{ section.settings.logo | image_url: width: 200 }}"
          alt="{{ shop.name }}"
          width="200"
          height="{{ 200 | divided_by: section.settings.logo.aspect_ratio | round }}"
          loading="eager"
        >
      {% else %}
        <span class="header-logo-text">{{ shop.name }}</span>
      {% endif %}
    </a>

    <!-- Desktop Navigation — reads from Shopify menu -->
    <nav class="header-nav" role="navigation" aria-label="Main navigation">
      <ul class="nav-list">
        {%- for link in main_menu.links -%}
          {%- if link.links.size > 0 -%}
            <li class="nav-item nav-item--has-dropdown">
              <a href="{{ link.url }}" aria-haspopup="true" aria-expanded="false">{{ link.title }}</a>
              <div class="nav-mega" role="menu">
                <div class="nav-mega__inner page-width">
                  {%- for child_link in link.links -%}
                    <div class="nav-mega__col">
                      {%- if child_link.links.size > 0 -%}
                        <h4 class="nav-mega__heading">{{ child_link.title }}</h4>
                        <ul>
                          {%- for grandchild_link in child_link.links -%}
                            <li><a href="{{ grandchild_link.url }}" role="menuitem">{{ grandchild_link.title }}</a></li>
                          {%- endfor -%}
                        </ul>
                      {%- else -%}
                        <a href="{{ child_link.url }}" role="menuitem" class="nav-mega__direct-link">{{ child_link.title }}</a>
                      {%- endif -%}
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            </li>
          {%- else -%}
            <li class="nav-item">
              <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    <div class="header-actions">
      <a href="/search" class="header-search" aria-label="Search">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/>
          <line x1="13" y1="13" x2="18" y2="18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </a>
      <a href="/account" class="header-account" aria-label="Account">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
          <circle cx="12" cy="7" r="4"/>
        </svg>
      </a>
      <a href="/cart" class="header-cart" aria-label="Cart ({{ cart.item_count }})">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>

  <!-- Mobile Navigation Drawer — reads from same Shopify menu -->
  <div id="MobileNav" class="mobile-nav" aria-hidden="true">
    <ul class="mobile-nav__list">
      {%- for link in main_menu.links -%}
        <li class="mobile-nav__item">
          <a href="{{ link.url }}" class="mobile-nav__link"{% if link.current %} aria-current="page"{% endif %}>{{ link.title }}</a>
          {%- if link.links.size > 0 -%}
            <ul class="mobile-nav__sublist">
              {%- for child_link in link.links -%}
                {%- if child_link.links.size > 0 -%}
                  <li class="mobile-nav__subheading">{{ child_link.title }}</li>
                  {%- for grandchild_link in child_link.links -%}
                    <li><a href="{{ grandchild_link.url }}" class="mobile-nav__sublink">{{ grandchild_link.title }}</a></li>
                  {%- endfor -%}
                {%- else -%}
                  <li><a href="{{ child_link.url }}" class="mobile-nav__sublink">{{ child_link.title }}</a></li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
    <div class="mobile-nav__footer">
      <a href="https://wa.me/97451835555" class="mobile-nav__wa">WhatsApp: +974 5183 5555</a>
    </div>
  </div>
</header>

<style>
  /* Mega-menu styles */
  .nav-item--has-dropdown { position: relative; }
  .nav-mega {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    min-width: 480px;
    background: var(--vz-white);
    border-radius: 16px;
    box-shadow: 0 12px 48px rgba(0,0,0,0.12);
    padding: 32px;
    z-index: 100;
    border: 1px solid var(--vz-border);
  }
  .nav-item--has-dropdown:hover .nav-mega,
  .nav-item--has-dropdown:focus-within .nav-mega { display: block; }
  .nav-mega__inner {
    display: flex;
    gap: 40px;
    padding: 0;
    max-width: none;
  }
  .nav-mega__col { min-width: 140px; }
  .nav-mega__heading {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--vz-gray);
    margin-bottom: 12px;
  }
  .nav-mega ul { list-style: none; padding: 0; margin: 0; }
  .nav-mega li { margin-bottom: 8px; }
  .nav-mega a {
    font-size: 15px;
    color: var(--vz-black);
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-mega a:hover { color: var(--vz-accent); }
  .nav-mega__direct-link {
    font-size: 15px;
    font-weight: 500;
    display: block;
    padding: 4px 0;
  }

  /* Account icon */
  .header-account { display: flex; align-items: center; }

  /* Mobile nav */
  .mobile-nav__footer {
    padding: 20px 24px;
    border-top: 1px solid var(--vz-border);
  }
  .mobile-nav__wa {
    font-size: 15px;
    font-weight: 600;
    color: var(--vz-green);
  }
  .mobile-nav__sublist {
    padding: 4px 0 8px 16px;
    list-style: none;
  }
  .mobile-nav__sublink {
    display: block;
    padding: 8px 0;
    font-size: 15px;
    color: var(--vz-gray);
  }
  .mobile-nav__subheading {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--vz-gray);
    padding: 12px 0 4px;
    list-style: none;
  }

  @media (max-width: 989px) {
    .nav-mega { display: none !important; }
  }
</style>

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "menu", "label": "Menu", "default": "main-menu" }
  ]
}
{% endschema %}
