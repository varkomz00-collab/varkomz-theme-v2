<div style="background: #ef4444; color: white; padding: 40px; text-align: center; margin-top: 2rem;">
  <h2 style="font-size: 2rem; margin-bottom: 1rem;">✅ TEST 5: Extra Section on Product Page</h2>
  <p style="font-size: 1.125rem;">This section was added to product.json via code. It renders BELOW the main product section.</p>
  <p style="margin-top: 1rem;">Current product: <strong>{{ product.title }}</strong> — {{ product.price | money }}</p>
  <p style="margin-top: 0.5rem;"><small>If you see this red box on any product page with the correct product name, non-homepage wiring works.</small></p>
</div>

{% schema %}
{
  "name": "Test 5 - Product Extra",
  "settings": [],
  "presets": [{ "name": "Test 5 - Product Extra" }]
}
{% endschema %}
