<section class="apple-split" id="Split-{{ section.id }}">
  <div class="apple-split__grid{% if section.settings.layout == 'image_right' %} apple-split__grid--flip{% endif %}">
    <div class="apple-split__media">
      {% if section.settings.image != blank %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
          loading="lazy"
          class="apple-split__img"
        >
      {% else %}
        <div class="apple-split__placeholder"></div>
      {% endif %}
    </div>
    <div class="apple-split__content">
      <div class="apple-split__inner">
        {% if section.settings.subtitle != blank %}
          <p class="apple-split__eyebrow">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="apple-split__title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.body != blank %}
          <div class="apple-split__body">{{ section.settings.body }}</div>
        {% endif %}
        {% if section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="apple-split__cta">
            {{ section.settings.cta_text }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {% endif %}
        {% if section.settings.secondary_text != blank %}
          <p class="apple-split__note">{{ section.settings.secondary_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .apple-split {
    overflow: hidden;
  }
  .apple-split__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 600px;
  }
  .apple-split__grid--flip .apple-split__media { order: 2; }
  .apple-split__media {
    position: relative;
    overflow: hidden;
  }
  .apple-split__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .apple-split__placeholder {
    width: 100%;
    height: 100%;
    min-height: 400px;
    background: linear-gradient(135deg, #0a1628 0%, #1a3a5c 100%);
  }
  .apple-split__content {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 64px;
    background: var(--vz-light-gray);
  }
  .apple-split__inner {
    max-width: 440px;
  }
  .apple-split__eyebrow {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--vz-gray);
    margin-bottom: 16px;
  }
  .apple-split__title {
    font-family: var(--font-heading);
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    color: var(--vz-black);
    margin: 0 0 20px;
  }
  .apple-split__body {
    font-size: 17px;
    line-height: 1.6;
    color: var(--vz-gray);
    margin-bottom: 32px;
  }
  .apple-split__body p { margin: 0; }
  .apple-split__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 17px;
    font-weight: 600;
    color: var(--vz-accent);
    text-decoration: none;
    transition: gap 0.2s ease;
  }
  .apple-split__cta:hover { gap: 12px; }
  .apple-split__note {
    margin-top: 16px;
    font-size: 14px;
    color: var(--vz-gray);
  }

  @media (max-width: 989px) {
    .apple-split__grid { grid-template-columns: 1fr; min-height: auto; }
    .apple-split__grid--flip .apple-split__media { order: 0; }
    .apple-split__media { aspect-ratio: 16/9; }
    .apple-split__content { padding: 56px 24px; }
  }
</style>

{% schema %}
{
  "name": "Lifestyle CTA",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "subtitle", "label": "Eyebrow", "default": "SURF PERFORMANCE MEETS STYLE" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Design Your Dream Boat" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>We source, stock, and ship the world's best water sports gear — configured for Gulf conditions.</p>" },
    { "type": "text", "id": "cta_text", "label": "Link text", "default": "Learn more" },
    { "type": "url", "id": "cta_link", "label": "Link" },
    { "type": "text", "id": "secondary_text", "label": "Note", "default": "Starting from QAR 80,000 | Financing Available" },
    { "type": "select", "id": "layout", "label": "Layout", "options": [
      { "value": "image_left", "label": "Image left" }, { "value": "image_right", "label": "Image right" }
    ], "default": "image_left" }
  ],
  "presets": [{ "name": "Lifestyle CTA" }]
}
{% endschema %}
