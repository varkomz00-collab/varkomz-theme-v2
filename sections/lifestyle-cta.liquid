<section class="lifestyle-cta-section" id="LifestyleCta-{{ section.id }}">
  <div class="page-width">
    <div class="lifestyle-cta__grid{% if section.settings.layout == 'image_right' %} lifestyle-cta__grid--reversed{% endif %}">
      <div class="lifestyle-cta__image-col">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading | escape }}"
            width="800"
            height="600"
            loading="lazy"
            class="lifestyle-cta__image"
          >
        {% else %}
          <div class="lifestyle-cta__placeholder">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
          </div>
        {% endif %}
      </div>
      <div class="lifestyle-cta__content-col">
        {% if section.settings.subtitle != blank %}
          <p class="lifestyle-cta__subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="lifestyle-cta__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.body != blank %}
          <div class="lifestyle-cta__body rte">{{ section.settings.body }}</div>
        {% endif %}
        {% if section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_link | default: '#' }}" class="btn btn-primary lifestyle-cta__btn">
            {{ section.settings.cta_text }}
          </a>
        {% endif %}
        {% if section.settings.secondary_text != blank %}
          <p class="lifestyle-cta__secondary">{{ section.settings.secondary_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  .lifestyle-cta-section {
    padding: 5rem 0;
  }
  .lifestyle-cta__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .lifestyle-cta__grid--reversed .lifestyle-cta__image-col {
    order: 2;
  }
  .lifestyle-cta__image {
    width: 100%;
    height: auto;
    border-radius: var(--vz-radius);
    object-fit: cover;
  }
  .lifestyle-cta__placeholder {
    aspect-ratio: 4/3;
    background: var(--vz-light-gray);
    border-radius: var(--vz-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--vz-gray);
  }
  .lifestyle-cta__subtitle {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--vz-accent);
    font-weight: 500;
    margin-bottom: 0.75rem;
  }
  .lifestyle-cta__heading {
    font-family: var(--font-heading);
    font-size: 2.25rem;
    font-weight: 700;
    color: var(--vz-black);
    line-height: 1.2;
    margin-bottom: 1.25rem;
  }
  .lifestyle-cta__body {
    font-size: 1.0625rem;
    color: var(--vz-gray);
    line-height: 1.7;
    margin-bottom: 2rem;
  }
  .lifestyle-cta__btn {
    display: inline-block;
  }
  .lifestyle-cta__secondary {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--vz-gray);
  }
  @media (max-width: 989px) {
    .lifestyle-cta__grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .lifestyle-cta__grid--reversed .lifestyle-cta__image-col {
      order: 0;
    }
    .lifestyle-cta__heading { font-size: 1.75rem; }
  }
</style>

{% schema %}
{
  "name": "Lifestyle CTA",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "SURF PERFORMANCE MEETS STYLE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Design Your Dream Boat"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>We source, stock, and ship the world's best water sports gear — configured for Gulf conditions. From wakeboards to boats.</p>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Schedule a Sea Trial"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "secondary_text",
      "label": "Secondary text",
      "default": "Starting from QAR 80,000 | Financing Available"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_left", "label": "Image left" },
        { "value": "image_right", "label": "Image right" }
      ],
      "default": "image_left"
    }
  ],
  "presets": [
    {
      "name": "Lifestyle CTA"
    }
  ]
}
{% endschema %}
