<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, height=device-height, minimum-scale=1.0">

  {%- comment -%}SEO: Optimized title tags per page type{%- endcomment -%}
  <title>
    {%- if template.name == 'index' -%}
      Tigé & ATX Boats, Hyperlite Wakeboards — Qatar's #1 Water Sports Dealer | {{ shop.name }}
    {%- elsif template.name == 'collection' and collection -%}
      {{ collection.title }} — Premium Water Sports Gear | {{ shop.name }}
    {%- elsif template.name == 'product' and product -%}
      {{ product.title }}{% if product.vendor != blank %} by {{ product.vendor }}{% endif %} | {{ shop.name }}
    {%- elsif template.name == 'search' -%}
      Search Results{% if search.terms != blank %} for "{{ search.terms | escape }}"{% endif %} | {{ shop.name }}
    {%- elsif template.name == 'page' -%}
      {%- if page.handle == 'contact' -%}
        Contact Varkomz — Get a Custom Boat Quote | {{ shop.name }}
      {%- else -%}
        {{ page.title }} | {{ shop.name }}
      {%- endif -%}
    {%- elsif template.name == 'blog' -%}
      {{ blog.title }} — Water Sports Tips & Guides | {{ shop.name }}
    {%- elsif template.name == 'article' -%}
      {{ article.title }} | {{ blog.title }} | {{ shop.name }}
    {%- else -%}
      {{ page_title }}
      {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' | escape }}"{% endif -%}
      {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
      {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
    {%- endif -%}
  </title>

  {%- comment -%}SEO: Optimized meta descriptions{%- endcomment -%}
  {%- if template.name == 'index' -%}
    <meta name="description" content="Qatar's authorized dealer for Tigé, ATX, Hyperlite & HO Sports. Premium boats, wakeboards & gear with free worldwide shipping from Doha. Shop 1000+ products.">
  {%- elsif template.name == 'collection' and collection.description != blank -%}
    <meta name="description" content="{{ collection.description | strip_html | truncate: 155 | escape }}">
  {%- elsif template.name == 'product' and product -%}
    <meta name="description" content="{{ product.description | strip_html | truncate: 155 | default: product.title | escape }}">
  {%- elsif page.handle == 'contact' -%}
    <meta name="description" content="Contact Varkomz for custom boat quotes, gear inquiries, and water sports advice. WhatsApp +974 5183 5555. Response within 2 hours.">
  {%- else -%}
    <meta name="description" content="{{ page_description | default: shop.description | escape }}">
  {%- endif -%}

  {%- comment -%}SEO: Canonical URL{%- endcomment -%}
  <link rel="canonical" href="{{ canonical_url }}">

  {%- comment -%}SEO: Pagination signals{%- endcomment -%}
  {%- if paginate -%}
    {%- if paginate.previous -%}<link rel="prev" href="{{ paginate.previous.url }}">{%- endif -%}
    {%- if paginate.next -%}<link rel="next" href="{{ paginate.next.url }}">{%- endif -%}
  {%- endif -%}

  <!-- Open Graph -->
  <meta property="og:site_name" content="{{ shop.name }}">
  <meta property="og:url" content="{{ canonical_url }}">
  <meta property="og:title" content="{{ page_title }}">
  <meta property="og:description" content="{{ page_description | default: shop.description | escape }}">
  {%- if page_image -%}<meta property="og:image" content="https:{{ page_image | image_url: width: 1200 }}">{%- endif -%}
  <meta property="og:type" content="{% if template.name == 'product' %}product{% elsif template.name == 'article' %}article{% else %}website{% endif %}">
  <meta name="twitter:card" content="summary_large_image">

  <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  {%- if settings.favicon != blank -%}
    <link rel="shortcut icon" href="{{ settings.favicon | image_url: width: 32, height: 32 }}" type="image/png">
  {%- endif -%}

  {{ content_for_header }}

  {{ 'base.css' | asset_url | stylesheet_tag }}

  {%- comment -%}Wire theme settings to CSS custom properties{%- endcomment -%}
  {% style %}
    :root {
      --color-primary: {{ settings.color_primary }};
      --color-secondary: {{ settings.color_secondary }};
      --color-accent: {{ settings.color_accent }};
      --color-background: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
    }
  {% endstyle %}

  {{ settings.font_heading | font_face }}
  {{ settings.font_body | font_face }}

  <script>
    document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
    window.theme = {
      moneyFormat: {{ shop.money_format | json }},
      strings: {
        addToCart: {{ 'products.add_to_cart' | t | json }},
        soldOut: {{ 'products.sold_out' | t | json }}
      }
    };
  </script>

  {%- comment -%}SEO: Organization + LocalBusiness JSON-LD{%- endcomment -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Varkomz",
    "url": "{{ shop.url }}",
    "logo": "{{ shop.url }}{{ 'logo.png' | asset_url }}",
    "description": "Qatar's authorized dealer for Tigé, ATX, Hyperlite & HO Sports. Premium boats, wakeboards and water sports gear.",
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+974-5183-5555",
      "contactType": "sales",
      "availableLanguage": ["English", "Arabic"]
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Doha",
      "addressCountry": "QA"
    },
    "sameAs": [
      "{{ settings.social_instagram }}",
      "{{ settings.social_twitter }}",
      "{{ settings.social_tiktok }}"
    ]
  }
  </script>
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  <a href="#MainContent" class="skip-to-content">Skip to content</a>

  {%- sections 'header-group' -%}

  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer-group' -%}

  {% render 'cart-drawer' %}
  {% section 'newsletter-popup' %}

  <!-- WhatsApp Float -->
  <a href="https://wa.me/97451835555" target="_blank" rel="noopener" class="whatsapp-float" aria-label="Chat on WhatsApp">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="white">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <script src="{{ 'theme.js' | asset_url }}" defer></script>
</body>
</html>
